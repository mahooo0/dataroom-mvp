# Vars for docker-compose.dev-infra.yml (fill in Dokploy env UI, NOT in repo)

# Postgres
POSTGRES_DB=dataroom
POSTGRES_USER=dataroom
POSTGRES_PASSWORD=replace-with-strong-password

# MinIO
MINIO_ROOT_USER=dataroom-minio
MINIO_ROOT_PASSWORD=replace-with-strong-password
S3_BUCKET=dataroom-files

# Traefik hosts
MINIO_HOST=minio.dataroom.holy-water.app
MINIO_CONSOLE_HOST=minio-console.dataroom.holy-water.app

# CORS allowed origins for the S3 API (comma-separated)
MINIO_CORS_ORIGINS=http://localhost:5173,https://dataroom.holy-water.app
