NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Postgres — matches docker/docker-compose.dev.yml credentials
DATABASE_URL=postgres://dev:dev@localhost:5432/dataroom

# Clerk — get from https://dashboard.clerk.com (development instance)
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# MinIO — same values in dev because both endpoints resolve to the local container
S3_ENDPOINT_INTERNAL=http://localhost:9000
S3_ENDPOINT_PUBLIC=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio-dev
S3_SECRET_KEY=minio-dev-password
S3_BUCKET=dataroom-files

# CORS — comma-separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:5173
