# Root env — used by docker-compose.prod.yml on Dokploy. NOT needed for local dev
# (local dev reads apps/api/.env.local and apps/web/.env.local separately).

# Domains
API_HOST=api.dataroom.holy-water.app
MINIO_HOST=minio.dataroom.holy-water.app
# Explicit origins only — the API and MinIO both refuse "*" in production.
# Comma-separate multiple; prefix a value with `re:` to use a regex (e.g. re:^https://.*\\.vercel\\.app$).
ALLOWED_ORIGINS=https://web-psi-ten-28.vercel.app,re:^https://.*\.vercel\.app$
MINIO_CORS_ORIGINS=https://web-psi-ten-28.vercel.app
# Web URL used to build share links.
PUBLIC_WEB_URL=https://web-psi-ten-28.vercel.app

# Postgres
POSTGRES_DB=dataroom
POSTGRES_USER=dataroom
POSTGRES_PASSWORD=replace-with-strong-password

# Clerk (production instance keys)
CLERK_PUBLISHABLE_KEY=pk_live_replace
CLERK_SECRET_KEY=sk_live_replace

# MinIO
# Root user — used by minio-init to provision the app service account below.
# The API never sees these; if you rotate them, restart minio + minio-init only.
MINIO_ROOT_USER=dataroom-minio
MINIO_ROOT_PASSWORD=replace-with-strong-password
S3_ENDPOINT_PUBLIC=https://minio.dataroom.holy-water.app
S3_BUCKET=dataroom-files

# Scoped service account for the API — put/get/delete on the bucket only,
# no admin, no console. Provisioned by minio-init on every startup.
DATAROOM_APP_KEY=dataroom-app-key
DATAROOM_APP_SECRET=replace-with-strong-32-byte-secret
