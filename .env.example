# Root env — used by docker-compose.prod.yml on Dokploy. NOT needed for local dev
# (local dev reads apps/api/.env.local and apps/web/.env.local separately).

# Domains
API_HOST=api.dataroom.holy-water.app
MINIO_HOST=minio.dataroom.holy-water.app
ALLOWED_ORIGINS=https://dataroom.vercel.app
MINIO_CORS_ORIGINS=https://dataroom.vercel.app

# Postgres
POSTGRES_DB=dataroom
POSTGRES_USER=dataroom
POSTGRES_PASSWORD=replace-with-strong-password

# Clerk (production instance keys)
CLERK_PUBLISHABLE_KEY=pk_live_replace
CLERK_SECRET_KEY=sk_live_replace

# MinIO
MINIO_ROOT_USER=dataroom-minio
MINIO_ROOT_PASSWORD=replace-with-strong-password
S3_ENDPOINT_PUBLIC=https://minio.dataroom.holy-water.app
S3_BUCKET=dataroom-files
