{
  "name": "dataroom-mvp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "check": "biome check",
    "check:fix": "biome check --write",
    "format": "biome format --write",
    "tunnel": "ssh -N -o ExitOnForwardFailure=yes -o ServerAliveInterval=30 -L 25432:localhost:15432 holy-water",
    "tunnel:bg": "ssh -f -N -o ExitOnForwardFailure=yes -o ServerAliveInterval=30 -L 25432:localhost:15432 holy-water && echo 'Tunnel opened in background on localhost:25432'",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:push": "pnpm --filter api db:push",
    "db:studio": "pnpm --filter api db:studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
